# Copy to .env.local and fill values.

# Supabase data planes
CIRCLEBOX_DATA_PLANE_US_PROJECT_REF=
CIRCLEBOX_DATA_PLANE_US_URL=
CIRCLEBOX_DATA_PLANE_US_SERVICE_ROLE_KEY=
CIRCLEBOX_DATA_PLANE_US_PUBLISHABLE_KEY=

CIRCLEBOX_DATA_PLANE_EU_PROJECT_REF=
CIRCLEBOX_DATA_PLANE_EU_URL=
CIRCLEBOX_DATA_PLANE_EU_SERVICE_ROLE_KEY=
CIRCLEBOX_DATA_PLANE_EU_PUBLISHABLE_KEY=

# Optional single-project fallback
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Worker-first ingest
WORKER_PUBLIC_BASE_URL=
US_SUPABASE_URL=
EU_SUPABASE_URL=
CONTROL_SUPABASE_URL=
US_SUPABASE_SERVICE_ROLE_KEY=
EU_SUPABASE_SERVICE_ROLE_KEY=
CONTROL_SUPABASE_SERVICE_ROLE_KEY=
DASHBOARD_WORKER_TOKEN=
DASHBOARD_SHARED_SECRET=
SYNTHETIC_ALERT_WEBHOOK_URL=

# Dashboard server
# Optional for legacy /dashboard routes; /app project routes do not require this.
DASHBOARD_DEFAULT_PROJECT_ID=
DASHBOARD_DEFAULT_REGION=us
DASHBOARD_US_SUPABASE_URL=
DASHBOARD_US_SUPABASE_SERVICE_ROLE_KEY=
DASHBOARD_EU_SUPABASE_URL=
DASHBOARD_EU_SUPABASE_SERVICE_ROLE_KEY=
DASHBOARD_WORKER_BASE_URL=
DASHBOARD_WORKER_TOKEN=
DASHBOARD_PUBLIC_BASE_URL=
DASHBOARD_CONTROL_SUPABASE_URL=
DASHBOARD_CONTROL_SUPABASE_SERVICE_ROLE_KEY=
DASHBOARD_APP_SESSION_SECRET=

# Operational tokens
SUPABASE_ACCESS_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# R2
CIRCLEBOX_R2_BUCKET_RAW=cb-reports-raw

# Optional smoke-test keys
CIRCLEBOX_INGEST_KEY=
CIRCLEBOX_INGEST_KEY_US=
CIRCLEBOX_INGEST_KEY_EU=
CIRCLEBOX_USAGE_KEY=
CIRCLEBOX_USAGE_KEY_US=
CIRCLEBOX_USAGE_KEY_EU=
